# Copy this file to `.env` for local development:
#   cp .env.example .env
# Flask reads these automatically via python-dotenv (see app.py / run.py).
# In production (Render), set these as real environment variables instead
# of committing a `.env` file.

# --- Core ------------------------------------------------------------------
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
PORT=5000
LOG_LEVEL=INFO

# --- Filesystem paths --------------------------------------------------------
# Override these to point at Render's persistent disk mount in production,
# e.g. /opt/render/project/src/persisted_data/saved_models
DATASET_DIR=dataset
SAVED_MODELS_DIR=saved_models
UPLOAD_DIR=uploads
REPORTS_DIR=reports
LOGS_DIR=logs
TENSORBOARD_DIR=logs/tensorboard

# --- Uploads / security ---------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60 per minute

# --- Model / architecture --------------------------------------------------
MODEL_NAME=retina_disease_model
MODEL_ARCHITECTURE=EfficientNetB7
IMAGE_SIZE=600
BATCH_SIZE=8
EPOCHS=50
FINE_TUNE_EPOCHS=20
FINE_TUNE_AT_LAYER=-60
LEARNING_RATE=0.0001
FINE_TUNE_LEARNING_RATE=0.00001
DROPOUT_RATE=0.4
L2_REGULARIZATION=0.0001
USE_MIXED_PRECISION=true
RANDOM_SEED=42
# "imagenet" (recommended) or "none" for random init in offline/air-gapped
# training environments without access to download pretrained weights
PRETRAINED_WEIGHTS=imagenet

# --- Dataset split ------------------------------------------------------------
TRAIN_SPLIT=0.70
VAL_SPLIT=0.15
TEST_SPLIT=0.15

# --- Callbacks --------------------------------------------------------------
EARLY_STOPPING_PATIENCE=8
REDUCE_LR_PATIENCE=4
REDUCE_LR_FACTOR=0.5
MIN_LEARNING_RATE=0.0000001

# --- Grad-CAM ------------------------------------------------------------
GRADCAM_LAST_CONV_LAYER=top_conv

APP_VERSION=1.0.0
